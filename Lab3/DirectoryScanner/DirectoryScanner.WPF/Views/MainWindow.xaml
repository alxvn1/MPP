<Window x:Class="DirectoryScanner.WPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DirectoryScanner.WPF.ViewModels"
        xmlns:models="clr-namespace:DirectoryScanner.Models;assembly=DirectoryScanner"
        Title="Directory Scanner" Height="600" Width="800" Background="#F5F5F5">
    
    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
            <Button Content="Выбрать папку" Command="{Binding SelectFolderCommand}" 
                    Padding="15,8" Background="#007ACC" Foreground="White" BorderThickness="0"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" 
                    Padding="15,8" Margin="10,0" Background="#D13438" Foreground="White" BorderThickness="0"/>
            <ProgressBar IsIndeterminate="True" Width="150" Height="20" Margin="10,0"
                         Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        </StackPanel>

        <TreeView Grid.Row="1" ItemsSource="{Binding Root.Children}" BorderThickness="0" Background="Transparent">
            <TreeView.Resources>
                <!-- Папки -->
                <HierarchicalDataTemplate DataType="{x:Type models:DirectoryNode}" ItemsSource="{Binding Children}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="📁" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Size, StringFormat=' ({0} байт)'}" Foreground="#666" Margin="5,0"/>
                        <TextBlock Text="{Binding Percentage, StringFormat=' {0:F1}%'}" Foreground="#007ACC" FontWeight="Bold" Margin="10,0"/>
                    </StackPanel>
                </HierarchicalDataTemplate>
                <!-- Файлы -->
                <DataTemplate DataType="{x:Type models:FileNode}">
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <TextBlock Text="📄" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding Size, StringFormat=' ({0} байт)'}" Foreground="#666" Margin="5,0"/>
                        <TextBlock Text="{Binding Percentage, StringFormat=' {0:F1}%'}" Foreground="#007ACC" Margin="10,0"/>
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>
    </Grid>
</Window>